# Base image
FROM ghcr.io/astral-sh/uv:python3.13-bookworm

# User setup
RUN adduser agent
USER agent
WORKDIR /home/agent

# Copy project files
COPY pyproject.toml uv.lock README.md ./
COPY src src
COPY scenarios scenarios

# Install dependencies using uv
RUN --mount=type=cache,target=/home/agent/.cache/uv,uid=1000 \
    uv sync --locked

# Expose common Purple agent ports
EXPOSE 9018 9019

# Select which Purple mode to run: single | multi | orchestrator
ENV PURPLE_AGENT_ROLE=orchestrator

# Command to start selected Purple mode (host/port can be overridden via CMD)
ENTRYPOINT ["sh", "-c", "case \"$PURPLE_AGENT_ROLE\" in single|single_executor) exec uv run scenarios/PurpleAgent/purple.py --type single \"$@\" ;; multi|multi_executor) exec uv run scenarios/PurpleAgent/purple.py --type multi \"$@\" ;; orchestrator|orchestrator_executor) exec uv run scenarios/PurpleAgent/purple_orchestrator.py \"$@\" ;; *) echo \"Invalid PURPLE_AGENT_ROLE: $PURPLE_AGENT_ROLE (expected: single|multi|orchestrator)\" >&2; exit 1 ;; esac", "purple-entrypoint"]
CMD ["--host", "0.0.0.0", "--port", "9018"]
